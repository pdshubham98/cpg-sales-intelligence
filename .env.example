# LLM Provider: "groq" (default, free tier) or "gemini" (paid fallback)
LLM_PROVIDER=groq

# Groq API key — get yours free at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Gemini API key — only needed if LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# API key for protecting endpoints (optional — leave empty to disable auth in dev/demo)
# In production: set to a strong random string, e.g. `openssl rand -hex 32`
SECRET_KEY=

# SQLite database path (created automatically at runtime)
DB_PATH=db/sales.db

# FastAPI base URL used by the Streamlit UI
API_BASE_URL=http://localhost:8000
